<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/black"
    android:padding="@dimen/defaultLayoutPadding">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/headerBackBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/transparent_button_bg"
        android:text="@string/backBtn"
        app:icon="@drawable/ic_arrow_back"
        app:backgroundTint="@null"/>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/headerUserImg"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="60dp"
        android:scaleType="centerCrop"
        android:src="@drawable/user_dp"
        app:shapeAppearanceOverlay="@style/CirecleButton"
        app:strokeColor="@color/brandColorsCyan"
        app:strokeWidth="4dp" />

    <TextView
        android:id="@+id/headerUserName"
        style="@style/TextAppearance.App.Heading3_Regular"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="170dp"
        android:text="User's Name"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/headerEmail"
        style="@style/TextAppearance.App.Body1_Regular"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="200dp"
        android:text="email@gmail.com"
        android:textColor="@color/white" />

</FrameLayout>