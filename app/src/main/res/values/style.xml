<?xml version="1.0" encoding="utf-8"?>

<resources>

    <!-- Heading 1 -->
    <style name="TextAppearance.App.Heading1_Bold" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/fontSizeHeading1</item>
        <item name="android:fontFamily">@font/sans_bold</item> <!-- Replace with your font -->
        <item name="android:textStyle">bold</item>
        <item name="android:lineHeight">38sp</item> <!-- 32 * 1.20 -->
        <item name="android:letterSpacing">0.0</item>
    </style>

    <style name="TextAppearance.App.Heading1_Regular" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/fontSizeHeading1</item>
        <item name="android:fontFamily">@font/sans_regular</item>
        <item name="android:lineHeight">38sp</item>
        <item name="android:letterSpacing">0.0</item>
    </style>

    <!-- Heading 2 -->
    <style name="TextAppearance.App.Heading2_Bold" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/fontSizeHeading2</item>
        <item name="android:fontFamily">@font/sans_bold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineHeight">29sp</item> <!-- 24 * 1.20 = 28.8 -->
        <item name="android:letterSpacing">0.0</item>
    </style>

    <!-- Heading 3 -->
    <style name="TextAppearance.App.Heading3_Regular" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/fontSizeHeading3</item>
        <item name="android:fontFamily">@font/sans_regular</item>
        <item name="android:lineHeight">22sp</item> <!-- 18 * 1.20 = 21.6 -->
        <item name="android:letterSpacing">0.0025</item> <!-- 0.25% -->
    </style>


    <!-- Button 1 -->
    <style name="TextAppearance.App.Button1" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/fontSizeButton1</item>
        <item name="android:fontFamily">@font/sans_semibold</item>
        <!-- Line height is AUTO, so we leave it out -->
        <item name="android:letterSpacing">0.0</item>
        <item name="textAllCaps">false</item> <!-- Prevents Android from forcing ALL CAPS -->
    </style>


    <!-- Body 1 -->
    <style name="TextAppearance.App.Body1_Medium" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/fontSizeBody1</item>
        <item name="android:fontFamily">@font/sans_regular</item>
        <item name="android:lineHeight">24sp</item> <!-- 16 * 1.50 = 24 -->
        <item name="android:letterSpacing">0.005</item> <!-- 0.5% -->
    </style>

    <style name="TextAppearance.App.Body1_Regular" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/fontSizeBody1</item>
        <item name="android:fontFamily">@font/sans_regular</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:letterSpacing">0.005</item>
    </style>

    <!-- Overline -->
    <style name="TextAppearance.App.Overline_Regular" parent="TextAppearance.AppCompat">
        <item name="android:textSize">@dimen/fontSizeOverline</item>
        <item name="android:fontFamily">@font/sans_regular</item>
        <!-- Line height is AUTO -->
        <item name="android:letterSpacing">0.015</item> <!-- 1.5% -->
        <item name="textAllCaps">true</item> <!-- Usually overlines are all caps -->
    </style>
    
    <style name="CirecleButton">
        <item name="cornerSize">20%</item>
    </style>

</resources>